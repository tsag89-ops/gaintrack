rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function createWithoutProFlag() {
      return !request.resource.data.keys().hasAny(['isPro']);
    }

    function doesNotModifyProFlag() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPro']);
    }

    // Legacy data path used by workout/progress sync.
    match /Users/{userId} {
      allow read, write: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // User profile path used by auth/profile store.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && createWithoutProFlag();
      allow update: if isOwner(userId) && doesNotModifyProFlag();
      allow delete: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Deny all other access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

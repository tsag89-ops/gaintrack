# GainTrack — environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.
#
# RevenueCat API key (get it from https://app.revenuecat.com → Project → API keys)
# Use the "Public SDK key" for the platform you are building for.
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
